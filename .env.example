NEXT_PUBLIC_TINA_CLIENT_ID=your_tina_client_id
TINA_TOKEN=your_tina_token
NEXT_PUBLIC_TINA_BRANCH=main

# Italianamente Studio
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_ALLOWED_EMAIL=editor@example.com,second-editor@example.com
AUTH_RESEND_KEY=re_...
AUTH_EMAIL_FROM=Italianamente Studio <studio@example.com>
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# GitHub App: Contents read/write and Pull requests read/write
GITHUB_REPOSITORY=Brickfielder/Italianamente
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: lets Studio discover the generated preview URL
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Local UI inspection only; ignored in production.
STUDIO_DEMO_MODE=false
